{
  "name": "famly-my-child-downloader",
  "version": "1.1.0",
  "description": "Famly photo downloader",
  "author": "Antonia Stenstad",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.antoniastenstad.famlydownloader",
    "productName": "Famly_Downloader",
    "win": {
      "target": "portable",
      "icon": "assets/icons/win/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icons/mac/icon.icns"
    },
    "artifactName": "${productName}-${os}.${ext}"
  },
  "dependencies": {
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1"
  }
}
